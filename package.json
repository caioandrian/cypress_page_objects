{
  "name": "cypress_e2e",
  "version": "1.0.0",
  "description": "Projeto de automação de testes E2E usando Cypress e Page Objects",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:open-prod": "cypress open --env fileConfig=prod",
    "cy:run-all": "cypress run --spec 'cypress/e2e/spec/exemplo/' --browser chrome --headless",
    "cy:run-exemplo-saucedemo": "cypress run --spec 'cypress/e2e/spec/exemplo/saucedemo.feature' --browser chrome --headless",
    "cypress:verify": "cypress verify",
    "update-packages": "npx npm-check-updates"
  },
  "keywords": [
    "cypress",
    "automation",
    "testing",
    "e2e",
    "pageobjects"
  ],
  "author": "Caio Andrian",
  "license": "MIT",
  "devDependencies": {
    "cypress-iframe": "^1.0.1",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-xpath": "^2.0.1",
    "fs-extra": "^11.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "dependencies": {
    "cypress": "^14.4.1",
    "mocha": "^10.8.2",
    "rimraf": "^6.0.1"
  }
}
